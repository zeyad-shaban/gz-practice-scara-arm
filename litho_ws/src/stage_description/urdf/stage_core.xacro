<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- Properties -->
    <xacro:property name="base_lx" value="0.2" />
    <xacro:property name="base_ly" value="0.2" />
    <xacro:property name="base_lz" value="0.02" />

    <xacro:property name="x_stage_lx" value="0.15" />
    <xacro:property name="x_stage_ly" value="0.15" />
    <xacro:property name="x_stage_lz" value="0.015" />

    <xacro:property name="y_stage_lx" value="0.15" />
    <xacro:property name="y_stage_ly" value="0.15" />
    <xacro:property name="y_stage_lz" value="0.015" />

    <xacro:property name="z_stage_lx" value="0.1" />
    <xacro:property name="z_stage_ly" value="0.1" />
    <xacro:property name="z_stage_lz" value="0.01" />

    <!-- Base -->
    <link name="base_footprint" />
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${base_lx} ${base_ly} ${base_lz}" />
            </geometry>
            <material name="black" />
        </visual>
    </link>

    <joint name="footprint_base_joint" type="fixed">
        <origin xyz="0 0 ${base_lz / 2}" rpy="0 0 0" />
        <parent link="base_footprint" />
        <child link="base_link" />
    </joint>

    <!-- X Stage -->
    <link name="x_stage_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${x_stage_lx} ${x_stage_ly} ${x_stage_lz}" />
            </geometry>

            <material name="red" />
        </visual>
    </link>

    <joint name="base_x_stage_joint" type="prismatic">
        <origin xyz="0 0 ${x_stage_lz / 2}" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="x_stage_link" />
        <axis xyz="1 0 0" />
        <limit lower="0.0" upper="0.025" effort="100" velocity="0.1" />
    </joint>

    <!-- Y Stage -->
    <link name="y_stage_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${y_stage_lx} ${y_stage_ly} ${y_stage_lz}" />
            </geometry>

            <material name="green" />
        </visual>
    </link>

    <joint name="x_y_stage_joint" type="prismatic">
        <origin xyz="0 0 ${y_stage_lz / 2}" rpy="0 0 0" />
        <parent link="x_stage_link" />
        <child link="y_stage_link" />
        <axis xyz="0 1 0" />
        <limit lower="0.0" upper="0.025" effort="100" velocity="0.1" />
    </joint>

    <!-- Z Stage -->
    <link name="z_stage_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${z_stage_lx} ${z_stage_ly} ${z_stage_lz}" />
            </geometry>

            <material name="cyan" />
        </visual>
    </link>

    <joint name="y_z_stage_joint" type="prismatic">
        <origin xyz="0 0 ${z_stage_lz / 2}" rpy="0 0 0" />
        <parent link="y_stage_link" />
        <child link="z_stage_link" />
        <axis xyz="0 0 1" />
        <limit lower="0.0" upper="0.025" effort="100" velocity="0.1" />
    </joint>

</robot>

